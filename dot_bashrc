# .bashrc

alias k='toolbox run -c ansible-control kubectl'
alias t='toolbox run -c ansible-control terraform'

# General helper to run ANY command inside your dev toolbox
alias tb='toolbox run -c ansible-control'

#tmux alias
alias t="tmux"

#tailscale alias
alias ts="sudo tailscale"

#git commit alias
alias gc="git commit -m"

#git add alias
alias ga="git add" 

#git push alias
alias gp="git push"

#git status alias 
alias gs="git status" 

# Source global definitions
if [ -f /etc/bashrc ]; then
    . /etc/bashrc
fi

# User specific environment
if ! [[ "$PATH" =~ "$HOME/.local/bin:$HOME/bin:" ]]; then
    PATH="$HOME/.local/bin:$HOME/bin:$PATH"
fi
export PATH

# Uncomment the following line if you don't like systemctl's auto-paging feature:
# export SYSTEMD_PAGER=

# User specific aliases and functions
if [ -d ~/.bashrc.d ]; then
    for rc in ~/.bashrc.d/*; do
        if [ -f "$rc" ]; then
            . "$rc"
        fi
    done
fi
unset rc

eval "$(starship init bash)"
