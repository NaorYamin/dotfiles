# .bashrc

# Set Neovim as the default editor
export EDITOR='nvim'
export VISUAL='nvim'

alias k='toolbox run -c ansible-control kubectl'
alias tf='toolbox run -c ansible-control terraform'
alias gh='toolbox run -c ansible-control gh'
alias h='toolbox run -c ansible-control helm'
alias l='toolbox run -c ansible-control luarocks'
alias fd='toolbox run -c ansible-control fd'
alias unar='toolbox run -c ansible-control unar'
alias t='toolbox run -c ansible-control tmux'
alias ts='sudo tailscale'
alias c='chezmoi' 
alias cl='toolbox run -c ansible-control claude'
alias nv='toolbox run -c ansible-control nvim'
alias k9s='toolbox run -c ansible-control k9s'

# Helper to run any one-off command in the toolbox
alias tb='toolbox run -c ansible-control'

#git status alias
alias gs="git status"

#git commit alias
alias gc="git commit -m"

#git add alias
alias ga="git add" 

#git push alias
alias gp="git push"

#git status alias 
alias gs="git status" 

# Source global definitions
if [ -f /etc/bashrc ]; then
    . /etc/bashrc
fi

# User specific environment
if ! [[ "$PATH" =~ "$HOME/.local/bin:$HOME/bin:" ]]; then
    PATH="$HOME/.local/bin:$HOME/bin:$PATH"
fi
export PATH

# Uncomment the following line if you don't like systemctl's auto-paging feature:
# export SYSTEMD_PAGER=

# User specific aliases and functions
if [ -d ~/.bashrc.d ]; then
    for rc in ~/.bashrc.d/*; do
        if [ -f "$rc" ]; then
            . "$rc"
        fi
    done
fi
unset rc

eval "$(starship init bash)"
export PATH=$HOME/.npm-global/bin:$PATH
alias k9s='toolbox run -c ansible-control k9s'
